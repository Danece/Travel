# ── iOS 最低部署目標 ───────────────────────────────────────────────────────────
platform :ios, '15.0'

# CocoaPods 統計數據會同步發送網路請求，影響 flutter build 速度，故停用
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug'   => :debug,
  'Profile' => :release,
  'Release' => :release,
}

# ── Flutter SDK 路徑解析 ───────────────────────────────────────────────────────
def flutter_root
  generated_xcode_build_settings_path = File.expand_path(
    File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__
  )
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} 不存在。" \
          "請先執行 flutter pub get 再執行 pod install。"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT 未找到於 #{generated_xcode_build_settings_path}。" \
        "請刪除 Generated.xcconfig 後重新執行 flutter pub get。"
end

require File.expand_path(
  File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root
)

flutter_ios_podfile_setup

# ── 主目標 ────────────────────────────────────────────────────────────────────
target 'Runner' do
  use_frameworks!
  use_modular_headers!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))

  target 'RunnerTests' do
    inherit! :search_paths
  end
end

# ── post_install hook ─────────────────────────────────────────────────────────
post_install do |installer|
  installer.pods_project.targets.each do |target|
    # Flutter 額外建置設定（必要，不可移除）
    flutter_additional_ios_build_settings(target)

    target.build_configurations.each do |config|
      # google_maps_flutter 及其相依套件（GoogleMaps framework）要求 iOS 14.0+，
      # 將所有 Pod 的部署目標統一設定為 15.0，消除 Xcode 編譯警告並確保相容性
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'

      # 避免 Xcode 15 使用者指令稿沙箱導致 CocoaPods 建置失敗
      config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
    end
  end
end
